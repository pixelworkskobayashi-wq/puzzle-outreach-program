---
const photos = [
  { src: '/images/gallery/01.jpg', alt: '子どもたちがノートPCで夢中に作業する様子' },
  { src: '/images/gallery/02.jpg', alt: '建築士が黒板前で児童に説明する様子' },
  { src: '/images/gallery/03.jpg', alt: '建築士が作品を解説する様子' },
  { src: '/images/gallery/04.jpg', alt: 'クラス全体でタブレット作業中の様子' },
  { src: '/images/gallery/05.jpg', alt: '建築士が机間を巡回しサポートする様子' },
  { src: '/images/gallery/06.jpg', alt: '児童がノートPCで間取りを作成する様子' },
  { src: '/images/gallery/07.jpg', alt: '出前授業の準備をする建築士たち' },
  { src: '/images/gallery/08.jpg', alt: '教室全体の授業風景' },
];
---

<section class="gallery" id="gallery">
  <div class="container">
    <p class="section-label fade-in">GALLERY</p>
    <div class="gallery-grid fade-in">
      {photos.map((photo, i) => (
        <button class="gallery-thumb" data-src={photo.src} data-alt={photo.alt} aria-label={photo.alt}>
          <img src={photo.src} alt={photo.alt} loading="lazy" />
        </button>
      ))}
    </div>
  </div>
</section>

<div id="gallery-modal" class="gallery-modal" aria-hidden="true">
  <div class="gallery-backdrop" id="gallery-backdrop"></div>
  <img id="gallery-modal-img" src="" alt="" class="gallery-modal-img" />
</div>

<style>
.gallery { padding: 80px 0; }
.gallery-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}
.gallery-thumb {
  display: block;
  aspect-ratio: 1;
  overflow: hidden;
  border-radius: var(--radius-md);
  border: none;
  padding: 0;
  cursor: pointer;
  background: var(--color-border);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.gallery-thumb:hover {
  transform: scale(1.03);
  box-shadow: var(--shadow-md);
}
.gallery-thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.3s ease;
}
.gallery-thumb:hover img { transform: scale(1.05); }

/* Modal */
.gallery-modal {
  position: fixed;
  inset: 0;
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}
.gallery-modal.is-open {
  opacity: 1;
  pointer-events: all;
}
.gallery-backdrop {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.88);
  cursor: pointer;
}
.gallery-modal-img {
  position: relative;
  z-index: 1;
  max-width: 90vw;
  max-height: 88vh;
  object-fit: contain;
  border-radius: var(--radius-md);
  box-shadow: 0 8px 40px rgba(0,0,0,0.4);
  transform: scale(0.85);
  transition: transform 0.3s ease;
  cursor: default;
}
.gallery-modal.is-open .gallery-modal-img {
  transform: scale(1);
}

@media (max-width: 768px) {
  .gallery-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>

<script>
  const modal = document.getElementById('gallery-modal')!;
  const modalImg = document.getElementById('gallery-modal-img') as HTMLImageElement;
  const backdrop = document.getElementById('gallery-backdrop')!;

  function openModal(src: string, alt: string) {
    modalImg.src = src;
    modalImg.alt = alt;
    modal.setAttribute('aria-hidden', 'false');
    requestAnimationFrame(() => modal.classList.add('is-open'));
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    modal.classList.remove('is-open');
    document.body.style.overflow = '';
    modal.addEventListener('transitionend', () => {
      modalImg.src = '';
      modal.setAttribute('aria-hidden', 'true');
    }, { once: true });
  }

  document.querySelectorAll<HTMLButtonElement>('.gallery-thumb').forEach((btn) => {
    btn.addEventListener('click', () => {
      const src = btn.dataset.src!;
      const alt = btn.dataset.alt ?? '';
      openModal(src, alt);
    });
  });

  backdrop.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
